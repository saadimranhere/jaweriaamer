# -----------------------------------------------------------------------------
# Public (exposed to the browser). Set in Vercel → Settings → Environment Variables.
# -----------------------------------------------------------------------------
# Production site URL (no trailing slash). Used for Open Graph and canonical URLs.
NEXT_PUBLIC_SITE_URL=https://www.example.com

# -----------------------------------------------------------------------------
# Server-only (never prefix with NEXT_PUBLIC_). Required for /admin features.
# -----------------------------------------------------------------------------
# Long random string used to sign the admin session cookie. Required in production.
# Generate e.g. openssl rand -base64 32
SESSION_SECRET=

# Credentials for /admin/login (plain text; restrict access via strong password).
# Often matches public contact.email in src/lib/contact.ts.
ADMIN_EMAIL=jaweriaamer001@gmail.com
ADMIN_PASSWORD=

# Password reset emails (https://resend.com). Required in production for "Forgot password".
# In development, if unset, the reset link is printed to the server console.
RESEND_API_KEY=
# Verified domain sender, e.g. "Jaweria Amer <reset@yourdomain.com>". Resend test default works only to your own email.
RESEND_FROM=

# After you reset via email, the new password is stored in data/admin-password.json (scrypt).
# Env ADMIN_PASSWORD is still used until that file exists.
